OPENQASM 2.0;
include "qelib1.inc";
qreg q[4];
creg c[4];

// INJETADO: alpha = 1.8000
// INJETADO: beta = 1.5000

// Parte do Circuito QAOA-like (Mixer/Driver Hamiltonian)
rx(1.8000) q[0];
cx q[0], q[1];
rx(1.8000) q[1];
cx q[1], q[2];
rx(1.8000) q[2];
cx q[2], q[3];
rx(1.8000) q[3];
cx q[3], q[0]; // Fechando o anel (cíclico)