// Exemplo 5: 100 qubits em superposicao
// Cada qubit independente — pode ser amostrado sem guardar vetor completo

EIEZ 2.0;

qreg q[100];
creg c[100];

for i in range 0 to 100 {
    h q[i];
}

measure q[0] -> c[0];
measure q[1] -> c[1];
measure q[2] -> c[2];
measure q[3] -> c[3];
measure q[4] -> c[4];
measure q[5] -> c[5];
measure q[6] -> c[6];
measure q[7] -> c[7];
measure q[8] -> c[8];
measure q[9] -> c[9];
